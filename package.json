{
  "name": "devtrees",
  "version": "0.0.5",
  "description": "Run a project's process-compose stack across multiple git worktrees without collision.",
  "homepage": "https://github.com/pantoninho/devtrees#readme",
  "bugs": {
    "url": "https://github.com/pantoninho/devtrees/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pantoninho/devtrees.git"
  },
  "bin": {
    "devtrees": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "vp pack",
    "test": "vp test run",
    "test:watch": "vp test watch",
    "lint": "vp lint",
    "check": "vp check",
    "dev": "vp pack --watch",
    "prepublishOnly": "npm run build && npm run check && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "clipanion": "^4.0.0-rc.4",
    "typanion": "^3.14.0",
    "vite-plus": "0.1.22",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.16.0"
}
